# LLM Provider (Venice AI — OpenAI-compatible endpoint)
LLM_PROVIDER=venice
LLM_API_KEY=your_venice_api_key
LLM_BASE_URL=https://api.venice.ai/api/v1
LLM_MODEL=llama-3.3-70b

# Database (SQLite for dev)
DATABASE_URL=sqlite+aiosqlite:///./pitches.db

# RAG
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTORSTORE_PATH=rag/vectorstore

# Telegram — create bot via @BotFather, get chat_id via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Frontend API URL (set in Vercel dashboard for prod)
NEXT_PUBLIC_API_URL=http://localhost:8000/api
